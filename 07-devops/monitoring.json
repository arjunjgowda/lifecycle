{
  "dashboard": {
    "title": "Production API Rate Limiting Health",
    "panels": [
      {
        "title": "Global 429 Rejections (per min)",
        "type": "timeseries",
        "targets": [{ "expr": "sum(rate(http_requests_total{status='429'}[1m]))" }]
      },
      {
        "title": "Redis Limiter Latency (P99)",
        "type": "gauge",
        "targets": [{ "expr": "histogram_quantile(0.99, sum(rate(redis_eval_duration_seconds_bucket[5m])) by (le))" }],
        "thresholds": {
          "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 0.005 },
            { "color": "red", "value": 0.01 }
          ]
        }
      },
      {
        "title": "Top Offending IPs",
        "type": "table",
        "targets": [{ "expr": "topk(10, sum(rate(http_requests_total{status='429'}[5m])) by (client_ip))" }]
      },
      {
        "title": "Fail Open Activations (Redis Unreachable)",
        "type": "timeseries",
        "targets": [{ "expr": "rate(rate_limiter_fail_open_total[1m])" }],
        "alert": {
          "name": "Rate Limiter Bypass Active",
          "condition": "A > 0 for 1m",
          "severity": "critical"
        }
      }
    ]
  }
}
